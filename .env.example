# Optional — enables the AI features (Smart Scan + Virtual Electrician).
# Point this at your deployed BreakerBox AI proxy (see server/README.md).
# Leave unset to run the app fully offline (manual + demo still work).
EXPO_PUBLIC_AI_PROXY_URL=

# Optional — must match PROXY_SHARED_SECRET on the proxy if you set one.
EXPO_PUBLIC_AI_PROXY_TOKEN=
